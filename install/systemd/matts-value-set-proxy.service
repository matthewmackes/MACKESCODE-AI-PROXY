[Unit]
Description=MDE LLM-PROXY Anthropic-compatible Proxy
Documentation=https://github.com/matthewmackes/MACKESCODE-AI-PROXY
After=network.target
Before=matts-console.service
Wants=network.target matts-console.service

[Service]
Type=simple
User=matts
Group=matts
WorkingDirectory=/var/lib/matts-value-set
EnvironmentFile=/etc/matts-value-set/environment.conf
Environment=PYTHONPATH=/usr/lib/matts-value-set/vendor/python:/usr/lib/matts-value-set
Environment=TMUX_TMPDIR=/var/lib/matts-value-set/tmux
ExecStart=/usr/bin/python3 /usr/lib/matts-value-set/do-anthropic-proxy.py \
  --host 127.0.0.1 \
  --port 18081 \
  --provider matts-value-set \
  --default-model deepseek-3.2 \
  --token-file /var/lib/matts-value-set/.mcnf-do-model-access-token \
  --cost-file /var/log/matts-value-set/usage.jsonl \
  --budget-file /var/lib/matts-value-set/budgets.json \
  --log-file /var/log/matts-value-set/proxy.jsonl
ExecStartPost=-/usr/bin/python3 /usr/lib/matts-value-set/matts-startup-service.py ensure-sidecars
Restart=always
RestartSec=10
StartLimitInterval=60
StartLimitBurst=5

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/matts-value-set /var/log/matts-value-set /tmp
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# Resource limits
LimitNOFILE=65536
LimitNPROC=4096

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=matts-value-set-proxy

[Install]
WantedBy=multi-user.target
