{
  "uid": "mde-llm-proxy-overview",
  "title": "MDE LLM-PROXY Overview",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["mde", "llm-proxy"],
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Console Ready",
      "targets": [{"expr": "matts_console_ready"}],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Requests By Model",
      "targets": [{"expr": "sum by (model, status) (rate(matts_model_requests_total[5m]))"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "Spend",
      "targets": [{"expr": "matts_budget_used_usd"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    }
  ]
}
