{
  "uid": "mde-llm-proxy-models",
  "title": "MDE LLM-PROXY Models",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["mde", "llm-proxy", "models"],
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "type": "timeseries",
      "title": "Latency p95",
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, model, route) (rate(matts_model_latency_ms_bucket[5m])))"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Cost By Model",
      "targets": [{"expr": "sum by (model, route) (rate(matts_model_cost_usd_total[5m]))"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Provider Errors",
      "targets": [{"expr": "sum by (provider, model, category) (rate(matts_provider_errors_total[5m]))"}],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ]
}
